Future<bool> validarSenha(String senha) async {
  // Expressões regulares para cada tipo de caractere
  final temMinuscula = RegExp(r'[a-z]').hasMatch(senha);
  final temMaiuscula = RegExp(r'[A-Z]').hasMatch(senha);
  final temNumero = RegExp(r'[0-9]').hasMatch(senha);
  final temEspecial = RegExp(r'[!@#\$%^&*(),.?":{}|<>]').hasMatch(senha);

  // Retorna true se todos os critérios forem atendidos
  return temMinuscula && temMaiuscula && temNumero && temEspecial;
}
