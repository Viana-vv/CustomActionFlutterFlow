import 'package:http/http.dart' as http;
import 'dart:convert';

Future<bool> chamarBebidas() async {
  try {
    final url = Uri.parse(
      'https://x8ki-letl-twmt.n7.xano.io/api:N5W6Wi0C/chamar_bebidas',
    );

    final response = await http.get(
      url,
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      },
    );

    if (response.statusCode == 200) {
      final data = jsonDecode(response.body);

      FFAppState().bebidas = [];

      for (final item in data) {
        FFAppState().bebidas.add(
              BebidasStruct(
                id: item['id'],
                nome: item['nome']?.toString(),
                descricao: item['descricao']?.toString(),
                preco: double.tryParse(item['preco'].toString()),
              ),
            );
      }

      FFAppState().update(() {});

      return true;
    } else {
      debugPrint('Erro status: ${response.statusCode}');
      return false;
    }
  } catch (e) {
    debugPrint('Erro: $e');
    return false;
  }
}
