import 'dart:convert';
import 'package:http/http.dart' as http;

Future<dynamic> dadosUsuario() async {
  try {
    final url = Uri.parse(
      'https://x8ki-letl-twmt.n7.xano.io/api:h4wuHhXB/dados',
    );

    // DEBUG
    print('TOKEN ANTES DO GET => ${FFAppState().authToken}');

    final token = FFAppState().authToken;

    // Se token estiver vazio
    if (token == null || token.isEmpty) {
      return {
        "success": false,
        "message": "Token vazio",
      };
    }

    final response = await http.get(
      url,
      headers: {
        'Authorization': 'Bearer $token',
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      },
    );

    print('STATUS => ${response.statusCode}');
    print('BODY => ${response.body}');

    final data = jsonDecode(response.body);

    if (response.statusCode == 200) {
      return data;
    } else {
      return {
        "success": false,
        "status": response.statusCode,
        "message": data["message"] ?? data["error"] ?? "Erro ao buscar dados",
      };
    }
  } catch (e) {
    print('ERRO => $e');

    return {
      "success": false,
      "message": e.toString(),
    };
  }
}
