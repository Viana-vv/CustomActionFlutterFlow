Future<bool> cadastrarUsuario(
  String name,
  String email,
  String password,
  String telefone,
  String cpf,
) async {
  try {
    final url =
        Uri.parse('https://x8ki-letl-twmt.n7.xano.io/api:FgvGAkB7/auth/signup');

    final response = await http.post(
      url,
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      },
      body: jsonEncode({
        'name': name,
        'email': email,
        'password': password,
        'telefone': telefone,
        'cpf': cpf,
      }),
    );

    if (response.statusCode == 200 || response.statusCode == 201) {
      return true;
    } else {
      return false;
    }
  } catch (e) {
    debugPrint('Erro: $e');
    return false;
  }
}
